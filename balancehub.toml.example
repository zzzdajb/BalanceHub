# BalanceHub 配置文件示例
# 复制此文件为 balancehub.toml 并根据需要修改

[cache]
enabled = true
ttl_seconds = 300
directory = ".balancehub/cache"

# ============================================================
# 内置 provider: mock（用于开发和测试）
# ============================================================
[providers.mock]
enabled = true
type = "mock"

# 可以在此处自定义 mock provider 的返回数据
# quota_limit = 2000
# quota_usage = 300
# balance = 10.0

# ============================================================
# 外部脚本插件（通过执行脚本获取数据）
#
# 约定: 每个插件放在 plugins/<name>/ 目录下，
# BalanceHub 会自动查找 main.py → main.sh → main.js 作为入口。
# 你只需要在 plugin 字段中指定目录路径即可。
#
# 合约:
#   输入 — BALANCEHUB_CONFIG 环境变量（JSON，包含本节的配置）
#   输出 — stdout 输出 ProviderRecord JSON 数组
#   退出码 — 0 成功，非 0 失败
# ============================================================

# Tavily 配额查询（Python 版，需要 pip install requests）
# 需要在 plugins/tavily-python/ 目录执行:
#   pip install -r plugins/tavily-python/requirements.txt
#   chmod +x plugins/tavily-python/main.py
#
# [providers.tavily-python]
# enabled = true
# type = "tavily"
# plugin = "./plugins/tavily-python"
# api_key = "sk-tavily-xxxxx"

# Tavily 配额查询（Bash 版，需要 curl，无需额外运行时）
# 需要: chmod +x plugins/tavily-bash/main.sh
#
# [providers.tavily-bash]
# enabled = true
# type = "tavily"
# plugin = "./plugins/tavily-bash"
# api_key = "sk-tavily-xxxxx"

# DeepSeek 余额查询（Bash 版，需要 curl，无需额外运行时）
# 需要: chmod +x plugins/deepseek-api-bash/main.sh
#
# [providers.deepseek-api-bash]
# enabled = true
# type = "deepseek"
# plugin = "./plugins/deepseek-api-bash"
# api_key = "sk-xxxxx"

# 其他外部脚本 provider 示例:
#
# [providers.perplexity]
# enabled = true
# type = "perplexity"
# script = "./scripts/perplexity.sh"
# cookie_file = "./secrets/perplexity.cookie"
